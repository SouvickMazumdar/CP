import math
from sortedcontainers import SortedList
class Solution:
    def findGoodIntegers(self, n: int) -> list[int]:
        mp={}
        i=1
        while i**3<=n:
            j=i+1
            while i**3+j**3<=n:
                d=i**3+j**3
                if d not in mp:
                    mp[d]=1
                else:
                    mp[d]+=1
                j+=1
            i+=1
        # for i in range(1,math.floor(n*0.33)):
        #     for j in range(i+1, math.floor(n*0.33)):
        #         d=i**3+j**3
        #         if d>n:
        #             break
        #         if d not in mp and d<=n:
        #             mp[d]=1
        #         else:
        #             mp[d]+=1
        # ans=SortedList()
        # print(mp)
        ans=[]
        for key,value in mp.items():
            if key <= n and value>=2:
                ans.append(key)
        ans.sort()
        return ans
        


                    
