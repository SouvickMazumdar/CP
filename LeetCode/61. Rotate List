# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        # lt=[]
        if head==None:
            return head
        cnt=0
        temp=head
        while temp:
            cnt+=1
            temp=temp.next
        k=k%cnt
        rt=cnt-k
        cat=head
        i=0;temp_1=None
        while cat:
            if i==rt:
                temp_1.next=None
                ret=cat
                while cat.next:
                    cat=cat.next
                    pass
                cat.next=head
                head=ret
                break
            i+=1
            temp_1=cat
            cat=cat.next
            
        return head
