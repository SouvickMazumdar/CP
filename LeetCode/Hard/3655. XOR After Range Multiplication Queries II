class Solution:
    def xorAfterQueries(self, nums: List[int], queries: List[List[int]]) -> int:
        MOD=10**9+7 #Prime Number
        n=len(nums)
        T=int(n**0.5)
        dic_lk=[[] for _ in range(T)]
        # print(dic_lk)
        for l,r,k,v in queries:
            if k<T:
                dic_lk[k].append((l,r,v))
            else:
                for i in range(l,r+1,k):
                    nums[i]=nums[i]*v%MOD
        
        dif=[1]*(n+T)
        # for i in dic_lk:
        #     print(i)
        # print(dic_lk)
        if len(dic_lk) !=0: 
            for k ,lt in enumerate(dic_lk):
                if len(lt)==0:
                    continue
                # print(lt)
                dif[:]=[1]*len(dif)
                for l,r,v in lt:
                    dif[l]=(dif[l]*v)%MOD
                    R=((r-l)//k+1)*k+l
                    dif[R]=dif[R]*pow(v,MOD-2,MOD)%MOD
                for i in range(k,n):
                    dif[i]=dif[i]*dif[i-k]%MOD
                for i in range(n):
                    nums[i]=nums[i]*dif[i]%MOD
        ans=0 
        for i in nums:
            ans^=i%MOD
        return ans
