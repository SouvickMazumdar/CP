from collections import defaultdict, deque

class Solution:
    def minJumps(self, arr):
        n = len(arr)

        if n == 1:
            return 0

        # value -> indices
        positions = defaultdict(list)

        for i, val in enumerate(arr):
            positions[val].append(i)

        dq = deque([0])
        visited = {0}

        steps = 0

        while dq:

            for _ in range(len(dq)):

                i = dq.popleft()

                if i == n - 1:
                    return steps

                # same value jumps
                for nb in positions[arr[i]]:
                    if nb not in visited:
                        visited.add(nb)
                        dq.append(nb)

                # IMPORTANT
                # remove to avoid future reprocessing
                positions[arr[i]].clear()

                # left
                if i - 1 >= 0 and i - 1 not in visited:
                    visited.add(i - 1)
                    dq.append(i - 1)

                # right
                if i + 1 < n and i + 1 not in visited:
                    visited.add(i + 1)
                    dq.append(i + 1)

            steps += 1
