class Solution:
    def rotateGrid(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m=len(grid);n=len(grid[0])
        mini=min(m,n)
        cnt=0
        copy_k=k
        first=0;second=0;fr=m;fc=n
        while cnt<mini//2:
            lt=[];i=first;j=second;right=False;left=False;up=False;down=True;perimeter=2*(fr-first)+2*((fc-second)-2)
            for t in range(perimeter):
                if down:
                    if i+1>=fr:
                        down=False;right=True;lt.append(grid[i][j]);j+=1
                    else:
                        lt.append(grid[i][j]);i+=1
                elif right:
                    if j+1>=fc:
                        up=True;right=False;lt.append(grid[i][j]);i-=1
                    else:
                        lt.append(grid[i][j]);j+=1
                elif up:
                    if i-1<first:
                        up=False;left=True;lt.append(grid[i][j]);j-=1
                    else:
                        lt.append(grid[i][j]);i-=1
                elif left:
                    if j-1<second:
                        # down=True;left=False
                        pass
                    else:
                        lt.append(grid[i][j]);j-=1
            k=k%perimeter
            print(k)
            # Rotate lt
            mt=[0]*perimeter;s=0
            # print(lt)
            while s<perimeter:
                mt[k]=lt[s]
                k+=1;k=k%perimeter
                s+=1
            k=copy_k
            # print(mt)
            down=True;left=False
            for t in range(perimeter):
                if down:
                    if i+1>=fr:
                        down=False;right=True;grid[i][j]=mt[t];j+=1
                    else:
                        grid[i][j]=mt[t];i+=1
                elif right:
                    if j+1>=fc:
                        up=True;right=False;grid[i][j]=mt[t];i-=1
                    else:
                        grid[i][j]=mt[t];j+=1
                elif up:
                    if i-1<first:
                        up=False;left=True;grid[i][j]=mt[t];j-=1
                    else:
                        grid[i][j]=mt[t];i-=1
                elif left:
                    if j-1<second:
                        pass
                    else:
                        grid[i][j]=mt[t];j-=1
            fr-=1;fc-=1
            cnt+=1;first+=1;second+=1
            # print(grid)
        return grid
            


